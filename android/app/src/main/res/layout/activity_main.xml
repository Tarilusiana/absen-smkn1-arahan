<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- WebView with SwipeRefresh -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Offline / No Connection View -->
    <LinearLayout
        android:id="@+id/offlineView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone"
        android:background="@android:color/white">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="@string/app_name"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tidak Ada Koneksi Internet"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1e293b"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pastikan WiFi atau data seluler aktif untuk menggunakan aplikasi absensi."
            android:textSize="14sp"
            android:textColor="#64748b"
            android:textAlignment="center"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Coba Lagi"
            android:textStyle="bold"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:backgroundTint="@color/primary" />
    </LinearLayout>

    <!-- Fake GPS Detected View -->
    <LinearLayout
        android:id="@+id/fakeGpsView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone"
        android:background="#fef2f2">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️"
            android:textSize="64sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aplikasi Fake GPS Terdeteksi"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#991b1b"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sistem keamanan mendeteksi penggunaan Mock Location. Mohon matikan aplikasi Fake GPS Anda untuk melanjutkan absensi."
            android:textSize="14sp"
            android:textColor="#7f1d1d"
            android:textAlignment="center"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btnRetryFakeGps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Coba Lagi"
            android:textStyle="bold"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:backgroundTint="#dc2626" />
    </LinearLayout>
</FrameLayout>
